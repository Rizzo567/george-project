# ─────────────────────────────────────────────────────────────────────
# Mister Barber — Variabili d'ambiente (Cloudflare Pages Functions)
#
# Questo file documenta le ENV usate dalle Functions in functions/api/.
# Su Cloudflare Pages vanno impostate in Settings → Environment variables.
# I valori qui sono PLACEHOLDER: non committare mai segreti reali.
#
# NB: le chiavi Supabase, se incollate dalla dashboard CF, possono contenere
#     whitespace interno (paste spezzato) → il codice sanifica con .replace(/\s/g,'').
# ─────────────────────────────────────────────────────────────────────

# ── Google Calendar — service account "George" ──────────────────────
# Email del service account (es. xxx@yyy.iam.gserviceaccount.com)
GEORGE_SERVICE_ACCOUNT_EMAIL=george-sa@example.iam.gserviceaccount.com
# Private key PEM. Newline come \n letterali (il codice fa .replace(/\\n/g,'\n')).
GEORGE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\nMIIE...REDACTED...\n-----END PRIVATE KEY-----\n"
# ID del calendario Google di George (override possibile via staff.calendar_id nel DB)
GEORGE_CALENDAR_ID=george_calendar_id@group.calendar.google.com

# ── Google Calendar — service account "Berlin" ──────────────────────
BERLIN_SERVICE_ACCOUNT_EMAIL=berlin-sa@example.iam.gserviceaccount.com
BERLIN_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\nMIIE...REDACTED...\n-----END PRIVATE KEY-----\n"
BERLIN_CALENDAR_ID=berlin_calendar_id@group.calendar.google.com

# ── Supabase ────────────────────────────────────────────────────────
# URL del progetto Supabase. NB: URL e ANON key sono pubblici per design e sono
# già hardcoded come costanti in functions/api/_google.js (SUPABASE_URL_PUBLIC /
# SUPABASE_ANON_PUBLIC). Queste env restano come fallback opzionale per moduli
# che le leggono (es. dedup slot in book.js).
SUPABASE_URL=https://your-project-ref.supabase.co
SUPABASE_ANON_KEY=eyJhbGciOi...public-anon-key...

# SERVICE ROLE KEY — SEGRETA. Bypassa RLS. Usata SOLO server-side dalle Functions
# (settings, preferences, loadShopConfig, persistEventId). MAI esposta al client.
SUPABASE_SERVICE_ROLE_KEY=eyJhbGciOi...service-role-key-SECRET...

# ── Admin allowlist per /api/settings (SEC-001) ─────────────────────
# Email (CSV) autorizzate a leggere/scrivere le Impostazioni. Solo questi
# utenti Supabase autenticati passano il gate admin in functions/api/settings.
# Se non impostata, il codice usa un fallback hardcoded con gli admin noti.
ADMIN_EMAILS=admin1@example.com,admin2@example.com

# ── Resend (email di conferma prenotazione) ─────────────────────────
RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxxxxxx
